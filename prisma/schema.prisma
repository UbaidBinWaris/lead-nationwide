generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  company   String?
  message   String
  ip        String?
  browser   String?
  os        String?
  device    String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
